# Recall.ai
RECALL_API_KEY=                    # required
RECALL_REGION=us-east-1
RECALL_BOT_NAME=Notetaker
POLL_INTERVAL_SECONDS=5
ENABLE_POLLER=true

# Webhooks (optional -- disabled by default; using polling instead)
ENABLE_WEBHOOKS=false
# RECALL_WEBHOOK_SECRET=
# PUBLIC_WEBHOOK_BASE_URL=

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/meetings.db
BLOBS_DIR=./backend/app/blobs
ALLOWED_ORIGINS=http://127.0.0.1:5173
FRONTEND_BASE_URL=http://127.0.0.1:5173

# Google Calendar (optional; auto-dispatch is off by default in the database)
ENABLE_GOOGLE_CALENDAR=true
CALENDAR_AUTO_DISPATCH_INTERVAL_SECONDS=60
CALENDAR_AUTO_DISPATCH_LOOKAHEAD_MINUTES=5
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# Frontend
VITE_API_BASE=http://127.0.0.1:8000
